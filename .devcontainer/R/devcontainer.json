// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "Existing Dockerfile",
	"build": {
		// Sets the run context to one level up instead of the .devcontainer folder.
		"context": ".",
		// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
		"dockerfile": "./Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"REditorSupport.r",
				"mechatroner.rainbow-csv",
				"ms-python.autopep8",
				"GrapeCity.gc-excelviewer",
				"VisualStudioExptTeam.vscodeintellicode",
				"ms-toolsai.jupyter",
				"ms-python.python",
				"ms-python.debugpy",
				"Mukundan.python-docs",
				"ms-azuretools.vscode-docker"
			]
		}
	},
	"mounts": [
		"source=/opt/,target=/opt/,type=bind,consistency=cached",
		"source=/labs,target=/labs,type=bind,consistency=cached",
		"source=/opt/megaseq-data/wcpilch/Projects/Junia_Collab_Spatial/output,target=/workspaces/Junia_Collab_Spatial/output,type=bind,consistency=cached",
		"source=/opt/megaseq-data/wcpilch/MMRF-ImmuneAtlas-Analysis-Sync/data,target=/workspaces/Junia_Collab_Spatial/data,type=bind,consistency=cached"
	]
	// Features to add to the dev container. More info: https://containers.dev/features.
